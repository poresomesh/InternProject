<% layout("/layouts/boilerplate") -%>
  <body>
    <div class="row">
      <div class="col-8">
        <br>
    <h3>Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="mb-3">
      <label for="title" class="for-label">title</label>
      <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required />
  
      </div>
      
      <div class="mb-3">
      <label for="description" class="for-label">description</label>
      <textarea
        name="listing[description]"
         class="form-control" required></textarea>
      </div>
      <div class="mb-3">
      <label for="image" class="for-label">Upload Image</label>
      <input
        name="listing[image]"
        type="file" class="form-control"
      />
     </div>

    <div class="row">
      

     <div class="mb-3 col-md-4">
      <label for="price" class="for-label">price</label>
      <input name="listing[price]" placeholder="enter price" type="number" class="form-control" required/>
      </div>

      <div class="mb-3 col-md-8">
      <label for="country" class="for-label">country</label>
      <input name="listing[country]" placeholder="enter country" type="text" class="form-control" required/>
      </div>
    </div>

      <div class="mb-3">
      <label for="location" class="for-label">location</label>
      <input
        name="listing[location]"
        placeholder="enter location"
        type="text" class="form-control" 
        required
      />
      </div>

    <div class="mb-3">
      <label for="category" class="form-label">Category</label>
      <select name="listing[category]" class="form-select" required>
        <option value="" disabled selected>Select Category</option>
        <option value="Trending">Trending (🔥)</option>
        <option value="Rooms">Rooms (🛏️)</option>
        <option value="Iconic Cities">Iconic Cities (🏙️)</option>
        <option value="Mountains">Mountains (⛰️)</option>
        <option value="Castles">Castles (🏰)</option>
        <option value="Amazing Pools">Amazing Pools (🏊)</option>
        <option value="Camping">Camping (⛺)</option>
        <option value="Farms">Farms (🚜)</option>
        <option value="Arctic">Arctic (❄️)</option>
        <option value="Domes">Domes (🛖)</option>
        <option value="Boats">Boats (🚢)</option>
      </select>
      <div class="invalid-feedback">Please select a category.</div>
    </div>
    
      <br>
      <button class="btn btn-dark add-btn">Add</button>
      <br><br>
    </form>
    </div>
    </div>
  </body>
