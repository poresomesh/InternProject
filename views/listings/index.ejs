<% layout("/layouts/boilerplate") -%>
<body>
    <div id="filters">
        <div class="filter" onclick="window.location.href='/?category=Trending'">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </div>
        <div class="filter" onclick="window.location.href='/?category=Rooms'">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </div>
        <div class="filter" onclick="window.location.href='/?category=Iconic Cities'">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </div>
        <div class="filter" onclick="window.location.href='/?category=Mountains'">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </div>
        <div class="filter" onclick="window.location.href='/?category=Castles'">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </div>
        <div class="filter" onclick="window.location.href='/?category=Amazing Pools'">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </div>
        <div class="filter" onclick="window.location.href='/?category=Camping'">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </div>
        <div class="filter" onclick="window.location.href='/?category=Farms'">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </div>
        <div class="filter" onclick="window.location.href='/?category=Arctic'">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </div>
        <div class="filter" onclick="window.location.href='?category=Domes'">
            <div><i class="fa-solid fa-igloo"></i></div>
            <p>Domes</p>
        </div>

        <div class="filter" onclick="window.location.href='?category=Boats'">
            <div><i class="fa-solid fa-ship"></i></div>
            <p>Boats</p>
        </div>
<!-- 
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
                <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
            </div>
        </div> -->
</div>
<br>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

<% for(let listing of allListings) { %>
  <a href="/listings/<%= listing._id %>" class="anchor">
    <div class="cards row-cols" >
      <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image" style="height:20rem" />
      <div class="card-body">
      <p class="card-text">
        <b><%= listing.title %></b> <br>
        &#8377;<%=listing.price ?.toLocaleString("en-IN")%> / night
      </p>
    </div>
  </div> 
  </a>
<% } %>

</div>
</body>
