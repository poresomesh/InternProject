<% layout("/layouts/boilerplate") -%>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-3">
    
    <h3><%=listing.title %></h3>

     </div>
    

    <div class="col-6 offset-3  " >
        <img src="<%= listing.image.url %>" class="card-img-top show-img mt-3" alt="listing-image" />
        <div class="card-body">
            <p class="card-text"><b></b>
                <i> Owned by : <%= listing.owner.username%></i> <br><br>
                <%=listing.description %><br><br>
                &#8377;<%=listing.price.toLocaleString("en-IN") %><br><br>
                <%=listing.location %><br><br>
                <%=listing.country %><br><br>
            </p>
        </div>
    </div>

    <br>
    <br>
    <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
    <div class="btns mt-3 d-flex align-items-center" >
        <a href="/listings/<%= listing._id %>/edit"  class="btn add-btn btn-dark col-1 offset-3">Edit</a>
        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn add-btn btn-dark offset-5">Delete</button>
        </form>
    </div>
    <% } %>


    <div class="col-8 offset-3 mb-3">
    <hr />
    <h4>Book Your Stay</h4>
    
    <form action="/listings/<%= listing._id %>/book" method="POST" novalidate class="needs-validation">
        <div class="row">
            <div class="mb-3 col-md-6">
                <label for="checkIn" class="form-label">Check-in</label>
                <input type="date" name="checkIn" id="checkIn" class="form-control" required>
                <div id="checkInError" class="text-danger small mt-1"></div>
            </div>
            <div class="mb-3 col-md-6">
                <label for="checkOut" class="form-label">Check-out</label>
                <input type="date" name="checkOut" id="checkOut" class="form-control" required>
            </div>
        </div>
        <button class="btn btn-primary w-100" id="bookBtn">Confirm Booking</button>
    </form>
</div>

<script>
    // Wrapping in quotes fixes the VS Code "Expression expected" error
    const data = '<%- bookedDates %>'; 
    const bookedDates = JSON.parse(data); // Turn the string back into a JS array
    
    const checkInInput = document.getElementById('checkIn');
    const checkOutInput = document.getElementById('checkOut');
    const errorDiv = document.getElementById('checkInError');
    const bookBtn = document.getElementById('bookBtn');

    // 1. Prevent selecting past dates
    const today = new Date().toISOString().split('T')[0];
    checkInInput.setAttribute('min', today);
    checkOutInput.setAttribute('min', today);

    // 2. Logic to check if date is already booked
    function isDateBooked(dateStr) {
        return bookedDates.includes(dateStr);
    }

    checkInInput.addEventListener('change', function() {
        if (isDateBooked(this.value)) {
            errorDiv.innerText = "This date is already booked!";
            this.value = ""; 
            bookBtn.disabled = true;
        } else {
            errorDiv.innerText = "";
            bookBtn.disabled = false;
            checkOutInput.setAttribute('min', this.value);
        }
    });

    checkOutInput.addEventListener('change', function() {
        if (isDateBooked(this.value)) {
            alert("This range overlaps with an existing booking.");
            this.value = "";
        }
    });
</script>



    <div class="col-8 offset-3 mb-3 mt-3">
        <hr>
        <% if (currUser) { %>
        <h4>Leave a review</h4>
         
        <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

            <div class="mb-3 mt-3"> 
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-basic">        
                <!-- <input type="range" min="1" max="5" id="rating" name="review[rating]"> -->
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            </div>

            <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required></textarea>
                <div class="invalid-feedback">please add feedback then Submit</div>
            </div>
             
            <button class="btn btn-outline-dark">submit</button>
            
        </form>
         
        <hr>
        <% } %>
        <div class="row">
        <p> <b>All Reviews </b></p>
        <% for(review of listing.reviews) { %>
            <div class="card col-5 ms-3 mb-3">
                <div class="card-body">
                    <h5 class="card-title">@<%= review.author.username %></h5>
                    <p class="starability-result card-text" data-rating="<%= review.rating  %>">Rated: 3 stars </p>
                    <p class="card-text"><%= review.comment %></p>     <br>
                </div>
                <% if (currUser && currUser._id.equals(review.author._id)) { %>
                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="post" >
                    <button class="btn btn-sm btn-dark"> Delete </button>
                </form>
                <% } %>
            </div>
        
        <% } %>
       </div>
    </div>
      
    </div>
</body>
 